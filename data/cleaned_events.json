s pla\u00e7a""}}",,"{""id"": 1, ""label"": {""fr"": ""Programm\u00e9"", ""en"": ""Scheduled"", ""io"": ""crwdns16100:0crwdne16100:0"", ""es"": ""Programado"", ""oc"": ""Programat""}}",,,20 mars 2025,7907391,,,,,,,Liban,"[{""type"": ""email"", ""value"": ""moyen-orient@auf.org""}]",,35.837527,34.436863,
